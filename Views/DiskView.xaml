<Page
    x:Class="TAY.Views.DiskView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="14,14,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Disk" FontSize="21" FontWeight="SemiBold" />
                <TextBlock Text="Volumes, usage, and health" FontSize="11" Foreground="{StaticResource TextMuted}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Style="{StaticResource GhostButton}" Click="RescanLast_Click">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE72C;" FontSize="13" />
                        <TextBlock Text="Refresh" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="0,20,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="12">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Drives}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:DriveItemVM">
                            <Border Style="{StaticResource SweetCard}" Margin="0,0,0,12" Padding="14">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="42" Height="42" CornerRadius="7" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                        <FontIcon Glyph="&#xEDA2;" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind Letter}" FontSize="15" FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind Label}" FontSize="15" Foreground="{StaticResource TextDim}" />
                                                <Border Background="#373737" CornerRadius="10" Padding="9,3">
                                                    <TextBlock Text="Healthy" Foreground="{StaticResource AccentGreen}" FontSize="11" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind UsedPercentStr}" FontSize="12" Foreground="{StaticResource TextDim}" HorizontalAlignment="Right" />
                                        </Grid>
                                        <ProgressBar Value="{x:Bind UsedPercent}" Minimum="0" Maximum="100" Height="5" Foreground="{StaticResource AccentMain}" Background="#3A3A3A" />
                                        <Grid>
                                            <TextBlock Text="{x:Bind CapacityStr}" FontSize="12" Foreground="{StaticResource TextDim}" />
                                            <Button Content="Analyze" Command="{x:Bind AnalyzeCommand}" Style="{StaticResource GhostButton}" Padding="8,3" HorizontalAlignment="Right" />
                                        </Grid>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="Hotspots:" FontSize="11" Foreground="{StaticResource TextMuted}" />
                                            <Border Background="#383838" CornerRadius="10" Padding="8,3">
                                                <TextBlock Text="Windows" FontSize="11" Foreground="{StaticResource TextMuted}" />
                                            </Border>
                                            <Border Background="#383838" CornerRadius="10" Padding="8,3">
                                                <TextBlock Text="Program Files" FontSize="11" Foreground="{StaticResource TextMuted}" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Style="{StaticResource SweetCard}" Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Spacing="8">
                        <ProgressBar IsIndeterminate="True" Height="3" Foreground="{StaticResource AccentMain}" />
                        <TextBlock Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SweetCard}" Padding="0" Visibility="{x:Bind ViewModel.HasLargeFiles, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <Grid Padding="14,10">
                            <TextBlock Text="Largest files" FontSize="13" FontWeight="SemiBold" />
                            <Button Content="Copy report" Style="{StaticResource GhostButton}" Click="CopyReport_Click" HorizontalAlignment="Right" Padding="8,3" />
                        </Grid>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.LargeFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:LargeFileVM">
                                    <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="0,1,0,0" Padding="14,8">
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{x:Bind Name}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{x:Bind Path}" FontSize="10" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{x:Bind SizeStr}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
