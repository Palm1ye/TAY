<Page
    x:Class="TAY.Views.HardwareView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14,14,14,12" Spacing="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Hardware" FontSize="21" FontWeight="SemiBold" />
                    <TextBlock Text="Detected devices and current state" FontSize="11" Foreground="{StaticResource TextMuted}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE72C;" FontSize="13" />
                            <TextBlock Text="Rescan" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Background="{StaticResource RowBg}"
                    BorderBrush="{StaticResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="13,10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE8FB;" Foreground="{StaticResource AccentMain}" FontSize="16" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Driver status available" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="Display and chipset drivers are checked in Boost Tuning." FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Open" Style="{StaticResource OutlineButton}" Click="ReviewDrivers_Click" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SweetCard}" Padding="0">
                <StackPanel>
                    <Grid Padding="14,11" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="5" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                            <FontIcon Glyph="&#xE950;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.CpuName, Mode=OneWay}" FontSize="15" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind ViewModel.CpuClockSpeed, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.CpuCores, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border Grid.Column="3" Background="{StaticResource AccentGreenSoft}" CornerRadius="10" Padding="9,3" VerticalAlignment="Center">
                            <TextBlock Text="OK" Foreground="{StaticResource AccentGreen}" FontSize="11" />
                        </Border>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource RowBorder}" />

                    <Grid Padding="14,11" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="5" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                            <FontIcon Glyph="&#xE7F4;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.GpuName, Mode=OneWay}" FontSize="15" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind ViewModel.DedicatedVram, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind ViewModel.TotalVram, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border Grid.Column="3" Background="{StaticResource AccentGreenSoft}" CornerRadius="10" Padding="9,3" VerticalAlignment="Center">
                            <TextBlock Text="OK" Foreground="{StaticResource AccentGreen}" FontSize="11" />
                        </Border>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource RowBorder}" />

                    <Grid Padding="14,11" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="5" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                            <FontIcon Glyph="&#xE8B7;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.RamCapacity, Mode=OneWay}" FontSize="15" />
                            <TextBlock Text="{x:Bind ViewModel.RamType, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="System" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border Grid.Column="3" Background="{StaticResource AccentGreenSoft}" CornerRadius="10" Padding="9,3" VerticalAlignment="Center">
                            <TextBlock Text="OK" Foreground="{StaticResource AccentGreen}" FontSize="11" />
                        </Border>
                    </Grid>

                    <Rectangle Height="1" Fill="{StaticResource RowBorder}" />

                    <Grid Padding="14,11" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="5" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                            <FontIcon Glyph="&#xE964;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.MotherboardName, Mode=OneWay}" FontSize="15" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind ViewModel.OsName, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Border Grid.Column="2" Background="{StaticResource AccentGreenSoft}" CornerRadius="10" Padding="9,3" VerticalAlignment="Center">
                            <TextBlock Text="OK" Foreground="{StaticResource AccentGreen}" FontSize="11" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border x:Name="HardwareDetailsHost" Style="{StaticResource SweetCard}" Padding="0">
                <StackPanel>
                    <Grid Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="Component details" FontSize="15" FontWeight="SemiBold" />
                            <TextBlock Text="Firmware, storage, network, and device-level fields" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                    </Grid>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.HardwareCategories, Mode=OneWay}">
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="False"
                                          HorizontalAlignment="Stretch"
                                          MinWidth="420"
                                          Background="Transparent"
                                          BorderBrush="{StaticResource RowBorder}"
                                          BorderThickness="0,1,0,0">
                                    <Expander.Header>
                                        <Grid ColumnSpacing="10" Padding="14,9" HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="32" Height="32" CornerRadius="5" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                                <FontIcon Glyph="{Binding IconGlyph}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Expander.Header>

                                    <ItemsControl ItemsSource="{Binding Rows}" Margin="14,0,14,10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="0,5" ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="138" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}" FontSize="11" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="11" Foreground="{StaticResource TextDim}" TextWrapping="WrapWholeWords" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button Content="Copy detected specs" Style="{StaticResource OutlineButton}" Click="CopySpecs_Click" HorizontalAlignment="Stretch" />
        </StackPanel>
    </ScrollViewer>
</Page>
