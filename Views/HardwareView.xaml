<Page
    x:Class="TAY.Views.HardwareView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="3,0,3,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Device inventory" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                <TextBlock Text="Hardware" FontFamily="Segoe UI" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" Margin="0,1,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <Button Content="Refresh" Style="{StaticResource SweetButton}" Click="Refresh_Click" Padding="12,6"/>
                <Button Content="Copy Specs" Style="{StaticResource OutlineButton}" Click="CopySpecs_Click" Padding="12,6"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SweetCard}" Grid.Column="0" Padding="16,14">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="44" Height="44" CornerRadius="6" Background="#1058D5C9" BorderBrush="#3358D5C9" BorderThickness="1">
                        <FontIcon Glyph="&#xE950;" FontSize="20" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Processor" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                        <TextBlock Text="{x:Bind ViewModel.CpuName, Mode=OneWay}" FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource TextMain}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{x:Bind ViewModel.CpuClockSpeed, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource SweetCard}" Grid.Column="1" Padding="16,14">
                <StackPanel Spacing="4">
                    <TextBlock Text="Memory" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="{x:Bind ViewModel.RamCapacity, Mode=OneWay}" FontFamily="Consolas" FontSize="27" FontWeight="Bold" Foreground="{StaticResource AccentWarning}"/>
                    <TextBlock Text="{x:Bind ViewModel.RamType, Mode=OneWay}" FontSize="10" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SweetCard}" Grid.Column="2" Padding="16,14">
                <StackPanel Spacing="4">
                    <TextBlock Text="VRAM" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="{x:Bind ViewModel.DedicatedVram, Mode=OneWay}" FontFamily="Consolas" FontSize="27" FontWeight="Bold" Foreground="{StaticResource AccentInfo}"/>
                    <TextBlock Text="{x:Bind ViewModel.GpuName, Mode=OneWay}" FontSize="10" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource SweetCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Component details" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                        <TextBlock Text="Expandable inventory grouped by the way Windows reports devices." FontSize="11" Foreground="{StaticResource TextDim}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.MotherboardName, Mode=OneWay}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="360"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.HardwareCategories, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8">
                            <Expander IsExpanded="True"
                                      Background="{StaticResource RowBgAlt}"
                                      BorderBrush="{StaticResource RowBorder}"
                                      BorderThickness="1"
                                      CornerRadius="5"
                                      Padding="0"
                                      HorizontalAlignment="Stretch">
                                <Expander.Header>
                                    <Grid Padding="10,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="32" Height="32" CornerRadius="5" Background="#1058D5C9" BorderBrush="#3358D5C9" BorderThickness="1">
                                            <FontIcon Glyph="{Binding IconGlyph}" FontSize="15" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                            <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="{Binding Summary}" FontSize="10" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="Details" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="18,0,0,0"/>
                                    </Grid>
                                </Expander.Header>

                                <ItemsControl ItemsSource="{Binding Rows}" Padding="68,0,18,10" HorizontalAlignment="Stretch" MinWidth="820">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="0,1,0,0" Padding="0,7" HorizontalAlignment="Stretch" MinWidth="734">
                                                <Grid ColumnSpacing="18" HorizontalAlignment="Stretch" MinWidth="734">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="190"/>
                                                        <ColumnDefinition Width="544"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Label}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="Consolas" FontSize="10.5" Foreground="{StaticResource TextMain}" TextWrapping="WrapWholeWords"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
