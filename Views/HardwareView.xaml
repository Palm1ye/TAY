<Page
    x:Class="TAY.Views.HardwareView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Page Header -->
        <Grid Margin="4,0,4,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="HARDWARE // SPECIFICATIONS" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="140"/>
                <TextBlock Text="sys_hardware.sh" FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="[ refresh_specs ]" Style="{StaticResource OutlineButton}" Click="Refresh_Click"/>
                <Button Content="[ copy_specs ]" Style="{StaticResource OutlineButton}" Click="CopySpecs_Click"/>
            </StackPanel>
        </Grid>

        <!-- 2x2 Bento Grid -->
        <Grid Grid.Row="1" Margin="-4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Card 1: Processor Unit -->
            <Border Style="{StaticResource SweetCard}" Grid.Row="0" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#1A7FE3A5" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                            <FontIcon Glyph="&#xE946;" FontSize="18" Foreground="{StaticResource AccentMain}"/>
                        </Border>
                        <TextBlock Text="Processor Unit" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.CpuName, Mode=OneWay}" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" TextWrapping="Wrap" Grid.Row="1" Margin="0,0,0,16"/>

                    <StackPanel Spacing="8" Grid.Row="2" VerticalAlignment="Bottom">
                        <Grid>
                            <TextBlock Text="Cores count" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.CpuCores, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#0AFFFFFF"/>
                        <Grid>
                            <TextBlock Text="Logical threads" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.CpuThreads, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#0AFFFFFF"/>
                        <Grid>
                            <TextBlock Text="Base frequency" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.CpuClockSpeed, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 2: Graphics & Display -->
            <Border Style="{StaticResource SweetCard}" Grid.Row="0" Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#1A7FE3A5" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                            <FontIcon Glyph="&#xE7B6;" FontSize="18" Foreground="{StaticResource AccentMain}"/>
                        </Border>
                        <TextBlock Text="Graphics &amp; Display" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.GpuName, Mode=OneWay}" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" TextWrapping="Wrap" Grid.Row="1" Margin="0,0,0,16"/>

                    <StackPanel Spacing="8" Grid.Row="2" VerticalAlignment="Bottom">
                        <Grid>
                            <TextBlock Text="Dedicated Video Memory (VRAM)" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.DedicatedVram, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#0AFFFFFF"/>
                        <Grid>
                            <TextBlock Text="Shared System Memory" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.SharedVram, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#0AFFFFFF"/>
                        <Grid>
                            <TextBlock Text="Total Graphic Memory" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.TotalVram, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 3: Physical Memory -->
            <Border Style="{StaticResource SweetCard}" Grid.Row="1" Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#1A7FE3A5" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                            <FontIcon Glyph="&#xE9A6;" FontSize="18" Foreground="{StaticResource AccentMain}"/>
                        </Border>
                        <TextBlock Text="Memory &amp; Cache" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Physical Installed RAM" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" Grid.Row="1" Margin="0,0,0,16"/>

                    <StackPanel Spacing="8" Grid.Row="2" VerticalAlignment="Bottom">
                        <Grid>
                            <TextBlock Text="Total capacity" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.RamCapacity, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentWarning}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#0AFFFFFF"/>
                        <Grid>
                            <TextBlock Text="Memory architecture" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.RamType, Mode=OneWay}" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 4: Motherboard & System -->
            <Border Style="{StaticResource SweetCard}" Grid.Row="1" Grid.Column="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Background="#1A7FE3A5" CornerRadius="8" Padding="8" Margin="0,0,12,0">
                            <FontIcon Glyph="&#xE95F;" FontSize="18" Foreground="{StaticResource AccentMain}"/>
                        </Border>
                        <TextBlock Text="Motherboard &amp; OS" FontFamily="Segoe UI" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{x:Bind ViewModel.MotherboardName, Mode=OneWay}" FontFamily="Segoe UI" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" TextWrapping="Wrap" Grid.Row="1" Margin="0,0,0,16"/>

                    <StackPanel Spacing="8" Grid.Row="2" VerticalAlignment="Bottom">
                        <Grid>
                            <TextBlock Text="Operating System" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.OsName, Mode=OneWay}" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#0AFFFFFF"/>
                        <Grid>
                            <TextBlock Text="OS Build Info" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="{x:Bind ViewModel.OsBuildInfo, Mode=OneWay}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Border Height="1" Background="#0AFFFFFF"/>
                        <Grid>
                            <TextBlock Text="Platform Kernel" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                            <TextBlock Text="WinRT / WASDK 1.5" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
