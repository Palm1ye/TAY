<Page
    x:Class="TAY.Views.ActivityView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="14,14,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Activity" FontSize="21" FontWeight="SemiBold" />
                <TextBlock Text="Events from this session" FontSize="11" Foreground="{StaticResource TextMuted}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Style="{StaticResource GhostButton}" Click="OpenDetached_Click">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE8A7;" FontSize="13" />
                        <TextBlock Text="Detach" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GhostButton}" Click="Filter_Click">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE71C;" FontSize="13" />
                        <TextBlock Text="Filter" />
                    </StackPanel>
                </Button>
                <Button Content="Clear" Style="{StaticResource GhostButton}" Click="Clear_Click" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource SweetCard}" Margin="0,20,0,0" Padding="0">
            <ListView x:Name="ActivityList"
                      ItemsSource="{x:Bind LogLines, Mode=OneWay}"
                      SelectionMode="None"
                      ItemContainerStyle="{StaticResource FlatListViewItemStyle}"
                      Padding="0,0,0,8">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="0,0,0,1" Padding="14,10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreen}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding}" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
