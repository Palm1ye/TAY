<Page
    x:Class="TAY.Views.NetworkView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    Unloaded="Page_Unloaded"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <StackPanel Margin="14,14,14,12" Spacing="12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Network" FontSize="21" FontWeight="SemiBold" />
                <TextBlock Text="{x:Bind ViewModel.LatencyLabel, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource GhostButton}" Command="{x:Bind ViewModel.RunSpeedTestCommand}" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <FontIcon Glyph="&#xE768;" FontSize="13" />
                    <TextBlock Text="Run speed test" />
                </StackPanel>
            </Button>
        </Grid>

        <Border Style="{StaticResource SweetCard}" Padding="14">
            <StackPanel Spacing="12">
                <ComboBox ItemsSource="{x:Bind ViewModel.Adapters}"
                          SelectedItem="{x:Bind ViewModel.SelectedAdapter, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          Background="{StaticResource RowBg}"
                          BorderBrush="{StaticResource RowBorder}"
                          Foreground="{StaticResource TextMain}"
                          HorizontalAlignment="Stretch"
                          Height="34" />

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="38" Height="38" CornerRadius="7" Background="#2549C7F7">
                        <FontIcon Glyph="&#xE839;" FontSize="18" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{x:Bind ViewModel.AdapterName, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{x:Bind ViewModel.AdapterDetails, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Border Grid.Column="2" Background="{StaticResource AccentGreenSoft}" CornerRadius="10" Padding="10,3" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.AdapterStatus, Mode=OneWay}" Foreground="{StaticResource AccentGreen}" FontSize="11" />
                    </Border>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource RowBg}" BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="5" Padding="12">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xE74A;" FontSize="12" Foreground="{StaticResource AccentMain}" />
                                <TextBlock Text="Download" FontSize="11" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.DownloadRate, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" />
                            <ProgressBar Value="{x:Bind ViewModel.DownloadValue, Mode=OneWay}" Minimum="0" Maximum="100" Height="3" Foreground="{StaticResource AccentMain}" Background="#3A3A3A" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{StaticResource RowBg}" BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="5" Padding="12">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xE74B;" FontSize="12" Foreground="{StaticResource AccentPurple}" />
                                <TextBlock Text="Upload" FontSize="11" Foreground="{StaticResource TextDim}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.UploadRate, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" />
                            <ProgressBar Value="{x:Bind ViewModel.UploadValue, Mode=OneWay}" Minimum="0" Maximum="100" Height="3" Foreground="{StaticResource AccentPurple}" Background="#3A3A3A" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="{StaticResource RowBgAlt}" BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="5" Padding="12">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Speed test" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.SpeedTestProvider, Mode=OneWay}" FontSize="10" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2" MinWidth="70">
                            <TextBlock Text="Down" FontSize="10" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" />
                            <TextBlock Text="{x:Bind ViewModel.SpeedTestDownload, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Right" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="2" MinWidth="70">
                            <TextBlock Text="Up" FontSize="10" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" />
                            <TextBlock Text="{x:Bind ViewModel.SpeedTestUpload, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Right" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Spacing="2" MinWidth="52">
                            <TextBlock Text="Ping" FontSize="10" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" />
                            <TextBlock Text="{x:Bind ViewModel.SpeedTestLatency, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <TextBlock Text="TOP CONSUMERS - CURRENT SESSION" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="2,8,0,0" />

        <Border Style="{StaticResource SweetCard}" Padding="0">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Consumers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:NetworkConsumerVM">
                        <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="0,0,0,1" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind Name}" FontSize="13" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Download}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentMain}" Margin="0,0,18,0" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Upload}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentPurple}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </StackPanel>
</Page>
