<Page
    x:Class="TAY.Views.BoostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Margin="4,0,4,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="520"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Performance, privacy, network, and shell tuning" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                <TextBlock Text="Boost" FontFamily="Segoe UI" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" Margin="0,2,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource SweetCard}" Padding="16,12" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock Text="{Binding BoostGuidance}" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <!-- Main Scrolling Bento Layout -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="4,0,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ================= LEFT COLUMN ================= -->
                <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,10,0">

                    <!-- Bento Card 1: Windows Debloat & Telemetry -->
                    <Border Style="{StaticResource SweetCard}">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0" Spacing="4">
                                    <TextBlock Text="Privacy Shield" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                    <TextBlock Text="Reduces Windows telemetry and assistant background activity with a reversible local backup." FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" IsOn="{Binding IsTelemetryDebloated, Mode=TwoWay}" OnContent="Debloated" OffContent="Active" FontFamily="Consolas" FontSize="11" MinWidth="0" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            </Grid>
                            
                            <StackPanel Spacing="6">
                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#204AEADC" BorderBrush="{StaticResource AccentMain}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="SERVICE" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="DiagTrack (Telemetry &amp; Diagnostics)" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Deactivates Microsoft Connected User Experiences tracking service." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#204AEADC" BorderBrush="{StaticResource AccentMain}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="SERVICE" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="dmwappushservice (WAP Routing)" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Stops local diagnostic wireless push routing daemons immediately." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#20F2C66D" BorderBrush="{StaticResource AccentWarning}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="REGISTRY" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentWarning}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="Cortana Assistant Policies" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Disables the Cortana background search assistant in HKLM:\Software\Policies." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#20F2C66D" BorderBrush="{StaticResource AccentWarning}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="REGISTRY" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentWarning}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="Telemetry DataCollection Levels" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Restricts Microsoft data collection levels to 'Security' (level 0), halting outbound dumps." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Bento Card 2: Game Booster -->
                    <Border Style="{StaticResource SweetCard}">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0" Spacing="4">
                                    <TextBlock Text="Game Focus Mode" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                    <TextBlock Text="Temporarily pauses high-overhead services and prioritizes known game processes. Reverts automatically." FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                    <Border Background="#10FFFFFF" BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="10" Padding="10,6" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding ExpectedGameBoost}" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource AccentWarning}" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1" IsOn="{Binding IsGameModeActive, Mode=TwoWay}" OnContent="Active" OffContent="Inactive" FontFamily="Consolas" FontSize="11" MinWidth="0" VerticalAlignment="Top" Margin="0,2,0,0"/>
                            </Grid>

                            <StackPanel Spacing="6">
                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#204AEADC" BorderBrush="{StaticResource AccentMain}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="MONITOR" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="Active Game Detection Service" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Monitors launching processes for known gaming binaries (notepad, cs2, etc.) to trigger boost mode." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#204AEADC" BorderBrush="{StaticResource AccentMain}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="PRIORITY" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="High-Priority CPU Escalation" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Escalates target game process CPU scheduler priority to HIGH to maximize core performance." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#20F47C7C" BorderBrush="{StaticResource AccentDanger}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="SERVICES" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentDanger}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="Pauses Heavy OS Background Systems" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Temporarily suspends resource-heavy services like SysMain (Superfetch), Windows Update, and Error Reporting." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" Background="{StaticResource RowBg}" CornerRadius="6" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#20F2C66D" BorderBrush="{StaticResource AccentWarning}" BorderThickness="1" CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="RESTORE" FontFamily="Consolas" FontSize="8.5" FontWeight="Bold" Foreground="{StaticResource AccentWarning}"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="2" Margin="10,0,0,0">
                                            <TextBlock Text="Automatic Performance Baseline Restore" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                            <TextBlock Text="Safely resumes all paused background services and normalizes priorities as soon as you exit the game." FontFamily="Segoe UI" FontSize="10" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Bento Card 3: Memory Cleaner -->
                    <Border Style="{StaticResource SweetCard}">
                        <Grid>
                            <StackPanel Spacing="12">
                                <TextBlock Text="Memory Sweep" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                <TextBlock Text="Trims idle working sets and standby cache to reclaim memory without closing applications." FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                <Border Background="#10FFFFFF" BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="10" Padding="10,6">
                                    <TextBlock Text="{Binding ExpectedMemoryBoost}" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource AccentWarning}" TextWrapping="Wrap"/>
                                </Border>

                                <Button Content="Deep Clean RAM" Command="{Binding DeepCleanRamCommand}" Style="{StaticResource SweetButton}" HorizontalAlignment="Stretch" Height="36"/>
                            </StackPanel>
                            
                            <!-- Premium Step-by-Step Progress Overlay -->
                            <Border Background="#FC0B1626" Visibility="{Binding IsRamCleaning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" CornerRadius="6" Padding="14">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="10">
                                    <ProgressRing IsActive="True" Width="24" Height="24" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Running memory sweep" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource AccentMain}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    
                                    <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Background="#050C16" CornerRadius="4" Padding="12,8" Height="100">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock Text="{Binding RamCleanLog, Mode=OneWay}" FontFamily="Consolas" FontSize="9.5" Foreground="#83F6EC" TextWrapping="Wrap" LineHeight="14"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>

                <!-- ================= RIGHT COLUMN ================= -->
                <StackPanel Grid.Column="1" Spacing="12" Margin="10,0,0,0">

                    <!-- Bento Card 4: Network & DNS Optimizer -->
                    <Border Style="{StaticResource SweetCard}">
                        <Grid>
                            <StackPanel Spacing="12">
                                <TextBlock Text="Network Optimizer" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                                <TextBlock Text="Flush resolver cache, reset TCP/IP, or apply the lowest-latency DNS profile." FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                                <Border Background="#10FFFFFF" BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="10" Padding="10,6">
                                    <TextBlock Text="{Binding ExpectedNetworkBoost}" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource AccentWarning}" TextWrapping="Wrap"/>
                                </Border>
                                <Border Background="#18F2C66D" BorderBrush="#44F2C66D" BorderThickness="1" CornerRadius="10" Padding="10,8">
                                    <TextBlock Text="Warning: Do not apply a recommended DNS profile if you already use a DNS service to bypass website blocks, provide filtering, parental controls, ad blocking, or custom routing. Scan is safe; Apply changes adapter DNS settings." FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource AccentWarning}" TextWrapping="Wrap"/>
                                </Border>

                                <StackPanel Spacing="8" Margin="0,4,0,8">
                                    <TextBlock Text="{Binding DnsScanResult, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentInfo}"/>
                                    <TextBlock Text="{Binding RecommendedDnsSummary, Mode=OneWay}" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                                    
                                    <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="4" Background="{StaticResource RowBg}">
                                        <ListView ItemsSource="{Binding DnsResults}" SelectionMode="None" MaxHeight="100" Background="Transparent" BorderThickness="0" Padding="0">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource TextMain}" Grid.Column="0"/>
                                                        <TextBlock Text="{Binding PrimaryIp}" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource TextMuted}" Grid.Column="1" Margin="16,0"/>
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding LatencyMs}" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                                                            <TextBlock Text=" ms" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </Border>
                                </StackPanel>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0" Content="Flush DNS" Command="{Binding FlushDnsCommand}" Style="{StaticResource OutlineButton}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Row="0" Grid.Column="1" Content="Reset TCP/IP" Command="{Binding ResetTcpIpCommand}" Style="{StaticResource OutlineButton}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Row="1" Grid.Column="0" Content="Scan DNS" Command="{Binding FindBestDnsCommand}" Style="{StaticResource SweetButton}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Row="1" Grid.Column="1" Content="Apply Recommended" Click="ApplyRecommendedDns_Click" IsEnabled="{Binding CanApplyRecommendedDns, Mode=OneWay}" Style="{StaticResource OutlineButton}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="Restore DHCP" Command="{Binding RestoreDefaultDnsCommand}" Style="{StaticResource OutlineButton}" HorizontalAlignment="Stretch" Margin="0,6,0,0"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Premium Step-by-Step Progress Overlay -->
                            <Border Background="#FC0B1626" Visibility="{Binding IsNetworkCleaning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" CornerRadius="6" Padding="14">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="10">
                                    <ProgressRing IsActive="True" Width="24" Height="24" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Running network optimization" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource AccentMain}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    
                                    <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Background="#050C16" CornerRadius="4" Padding="12,8" Height="100">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock Text="{Binding NetworkCleanLog, Mode=OneWay}" FontFamily="Consolas" FontSize="9.5" Foreground="#83F6EC" TextWrapping="Wrap" LineHeight="14"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Bento Card 5: Context Menu Manager -->
                    <Border Style="{StaticResource SweetCard}">
                        <Grid>
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Context Menu Manager" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshContextHandlersCommand}" Style="{StaticResource OutlineButton}" Padding="10,4" FontSize="11"/>
                                </Grid>
                                
                                <TextBlock Text="Scan and toggle third-party shell extensions under HKCR right-click paths." FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextDim}"/>

                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="4" Background="{StaticResource RowBg}">
                                    <ListView ItemsSource="{Binding ContextHandlers}" SelectionMode="None" Height="140" Background="Transparent" BorderThickness="0" Padding="0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource RowBorder}" Padding="8,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Grid Grid.Column="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                <TextBlock Text="{Binding Name}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMain}"/>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="Source: " FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                                    <TextBlock Text="{Binding SourceType}" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                                </StackPanel>
                                                            </StackPanel>
     
                                                            <TextBlock Grid.Column="1" Text="{Binding DefaultValue}" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}" MaxWidth="130" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        </Grid>
                                                        
                                                        <!-- Dynamic binding through the ViewModel command -->
                                                        <ToggleSwitch Grid.Column="1" IsOn="{Binding IsEnabled, Mode=OneWay}" Toggled="OnContextMenuToggled" MinWidth="0" VerticalAlignment="Center" OnContent="" OffContent="" Margin="12,0,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Border>
                            </StackPanel>
                            
                            <!-- Micro-animation Progress Overlay -->
                            <Border Background="#E50A1220" Visibility="{Binding IsContextScanning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" CornerRadius="6">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                    <ProgressRing IsActive="True" Width="28" Height="28" Foreground="{StaticResource AccentMain}"/>
                                    <TextBlock Text="Scanning shell extensions" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource AccentMain}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Filtering third-party right-click handlers" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                             </Border>
                        </Grid>
                     </Border>

                    <!-- Bento Card 6: Hardware Driver Checker -->
                    <Border Style="{StaticResource SweetCard}">
                        <Grid>
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Driver Status" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="(" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding OutdatedDriversCount, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" FontWeight="Bold"/>
                                        <TextBlock Text="old)" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Scan" Command="{Binding RefreshDriversCommand}" Style="{StaticResource OutlineButton}" Padding="10,4" FontSize="11"/>
                                </Grid>
                                
                                <TextBlock Text="Scans display and chipset components. Evaluates driver dates for security and updates." FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextDim}"/>

                                <Border BorderBrush="{StaticResource RowBorder}" BorderThickness="1" CornerRadius="4" Background="{StaticResource RowBg}">
                                    <ListView ItemsSource="{Binding Drivers}" SelectionMode="None" Height="160" Background="Transparent" BorderThickness="0" Padding="0">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource RowBorder}" Padding="8,6">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DeviceName}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMain}" TextTrimming="CharacterEllipsis"/>
                                                        
                                                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding DeviceClass}" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="v" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                                <TextBlock Text="{Binding DriverVersion}" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Provider}" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                        </StackPanel>
                                                        
                                                        <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <Border Background="#20F2C66D" BorderBrush="{StaticResource AccentWarning}" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="{Binding IsOutdated, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                                                                <TextBlock Text="Outdated" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource AccentWarning}" FontWeight="Bold"/>
                                                            </Border>
                                                            <Border Background="#204AEADC" BorderBrush="{StaticResource AccentMain}" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="{Binding IsOutdated, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">
                                                                <TextBlock Text="Up to date" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource AccentMain}" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Border>
                            </StackPanel>
                            
                            <!-- Micro-animation Progress Overlay -->
                            <Border Background="#E50A1220" Visibility="{Binding IsDriverScanning, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" CornerRadius="6">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                    <ProgressRing IsActive="True" Width="28" Height="28" Foreground="{StaticResource AccentMain}"/>
                                    <TextBlock Text="Scanning signed drivers" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource AccentMain}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Evaluating driver dates" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
