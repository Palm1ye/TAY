<Page
    x:Class="TAY.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Margin="4,0,4,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="SETTINGS // SYSTEM_CONFIGURATION" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="140"/>
                <TextBlock Text="sys_config.sh" FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="[ copy_info ]" Style="{StaticResource OutlineButton}" Click="CopyInfo_Click"/>
            </StackPanel>
        </Grid>

        <!-- Settings Bento Box Card -->
        <StackPanel Grid.Row="1">
            <Border Style="{StaticResource SweetCard}">
                <StackPanel Spacing="16">
                    <TextBlock Text="// APP CONFIG DUMP" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="80" Margin="0,0,0,8"/>
                    
                    <!-- Property Row 1 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SYS // APP_NAME      :" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                        <TextBlock Text="{x:Bind ViewModel.AppName}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" FontWeight="Bold" Grid.Column="1"/>
                    </Grid>

                    <!-- Property Row 2 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SYS // APP_VERSION   :" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                        <TextBlock Text="{x:Bind ViewModel.AppVersion}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentMain}" FontWeight="Bold" Grid.Column="1"/>
                    </Grid>

                    <!-- Property Row 3 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SYS // APP_CHANNEL   :" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                        <TextBlock Text="stable_terminal" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" FontWeight="Bold" Grid.Column="1"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
