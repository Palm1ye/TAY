<Page
    x:Class="TAY.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14,14,14,12" Spacing="12">
            <StackPanel>
                <TextBlock Text="Settings" FontSize="21" FontWeight="SemiBold" />
                <TextBlock Text="Preferences and behavior" FontSize="11" Foreground="{StaticResource TextMuted}" />
            </StackPanel>

            <Border Style="{StaticResource SweetCard}" Padding="0" Margin="0,10,0,0">
                <StackPanel>
                    <Grid Padding="14,13" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Pin window on top" FontSize="14" />
                            <TextBlock Text="Keep TAY visible above other apps" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.PinWindowOnTop, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" />
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource RowBorder}" />
                    <Grid Padding="14,13" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Launch at sign-in" FontSize="14" />
                            <TextBlock Text="Start the toolbox automatically with Windows" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.LaunchAtSignIn, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" />
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource RowBorder}" />
                    <Grid Padding="14,13" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Background scanning" FontSize="14" />
                            <TextBlock Text="Re-evaluate startup and drivers every 24 hours" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.BackgroundScanning, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" />
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource RowBorder}" />
                    <Grid Padding="14,13" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Send anonymous diagnostics" FontSize="14" />
                            <TextBlock Text="Help improve detection rules" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.SendAnonymousDiagnostics, Mode=TwoWay}" OnContent="" OffContent="" MinWidth="0" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SweetCard}" Padding="14">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="42" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Image Width="36" Height="36" VerticalAlignment="Center">
                        <Image.Source>
                            <SvgImageSource UriSource="ms-appx:///Assets/tay.svg" />
                        </Image.Source>
                    </Image>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{x:Bind ViewModel.AppName}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.WindowsInfo, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="Check for updates" Style="{StaticResource GhostButton}" Command="{x:Bind ViewModel.CheckUpdatesCommand}" IsEnabled="{x:Bind ViewModel.IsNotChecking, Mode=OneWay}" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Style="{StaticResource SweetCard}" Padding="14">
                <StackPanel Spacing="8">
                    <Grid>
                        <TextBlock Text="Update status" FontSize="14" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.AppVersion}" FontSize="12" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" />
                    </Grid>
                    <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="Copy info" Style="{StaticResource OutlineButton}" Click="CopyInfo_Click" HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="Release page" Style="{StaticResource OutlineButton}" Command="{x:Bind ViewModel.OpenReleasePageCommand}" HorizontalAlignment="Stretch" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="{x:Bind ViewModel.MaintenanceStatus, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="2,0,2,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
