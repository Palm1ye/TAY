<Page
    x:Class="TAY.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Margin="4,0,4,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Updates, diagnostics, and safety controls" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                <TextBlock Text="Settings" FontFamily="Segoe UI" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Copy Info" Style="{StaticResource OutlineButton}" Click="CopyInfo_Click"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Padding="0,0,8,12">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SweetCard}" Grid.Column="0">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Application" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="{x:Bind ViewModel.AppName}" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="Native Windows optimizer with real-time telemetry, cleanup tools, startup control, and reversible system tuning." FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Version" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                                <TextBlock Text="{x:Bind ViewModel.AppVersion}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentMain}" FontWeight="Bold" Grid.Column="1"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Channel" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                                <TextBlock Text="{x:Bind ViewModel.AppChannel}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" FontWeight="Bold" Grid.Column="1"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Privileges" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                                <TextBlock Text="{x:Bind ViewModel.ElevationStatus}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" Grid.Column="1"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SweetCard}" Grid.Column="1">
                        <StackPanel Spacing="14">
                            <TextBlock Text="System Snapshot" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="{x:Bind ViewModel.WindowsInfo, Mode=OneWay}" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind ViewModel.HardwareSummary, Mode=OneWay}" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                            <TextBlock Text="{x:Bind ViewModel.ArchitectureInfo}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Refresh Snapshot" Style="{StaticResource OutlineButton}" Command="{x:Bind ViewModel.RefreshSystemSummaryCommand}"/>
                                <Button Content="Copy Diagnostics" Style="{StaticResource SweetButton}" Click="CopyDiagnostics_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource SweetCard}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Update Control" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.3*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Current" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{x:Bind ViewModel.AppVersion}" FontFamily="Consolas" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMain}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Latest" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{x:Bind ViewModel.LatestVersion, Mode=OneWay}" FontFamily="Consolas" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Status" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                                <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextMain}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Check Updates" Style="{StaticResource OutlineButton}" Command="{x:Bind ViewModel.CheckUpdatesCommand}" IsEnabled="{x:Bind ViewModel.IsNotChecking, Mode=OneWay}"/>
                            <Button Content="Download Update" Style="{StaticResource SweetButton}" Command="{x:Bind ViewModel.DownloadUpdateCommand}" IsEnabled="{x:Bind ViewModel.CanDownloadUpdate, Mode=OneWay}" Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Content="Release Page" Style="{StaticResource OutlineButton}" Command="{x:Bind ViewModel.OpenReleasePageCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource SweetCard}" Grid.Column="0">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Local Maintenance" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="{x:Bind ViewModel.BackupStatus, Mode=OneWay}" FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" TextWrapping="Wrap"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="App data" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                                <TextBlock Text="{x:Bind ViewModel.AppDataPath}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" TextTrimming="CharacterEllipsis" Grid.Column="1"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Backups" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                                <TextBlock Text="{x:Bind ViewModel.BackupFiles, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" TextWrapping="Wrap" Grid.Column="1"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Refresh State" Style="{StaticResource OutlineButton}" Command="{x:Bind ViewModel.RefreshMaintenanceStateCommand}"/>
                                <Button Content="Open Data" Style="{StaticResource OutlineButton}" Command="{x:Bind ViewModel.OpenAppDataFolderCommand}"/>
                                <Button Content="Clear Backups" Style="{StaticResource DestructiveOutlineButton}" Click="ClearBackups_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SweetCard}" Grid.Column="1">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Safety Model" FontFamily="Segoe UI" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                            <TextBlock Text="High-impact operations now surface confirmations, reversible backup state, and clearer status messages." FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cleaner" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                                <TextBlock Text="Confirms selected targets before deletion" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextMain}" Grid.Column="1"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Processes" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
                                <TextBlock Text="Protects critical Windows processes and confirms End Task" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextMain}" Grid.Column="1"/>
                            </Grid>
                            <TextBlock Text="{x:Bind ViewModel.MaintenanceStatus, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentMain}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
