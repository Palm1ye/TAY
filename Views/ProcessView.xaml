<Page
    x:Class="TAY.Views.ProcessView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- Terminal Column Headers -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="3,0,3,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Active processes and memory usage" FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource TextDim}"/>
                <TextBlock Text="Processes" FontFamily="Segoe UI" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextMain}" Margin="0,1,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Refresh" Command="{x:Bind ViewModel.LoadProcessesCommand}" IsEnabled="{x:Bind ViewModel.IsNotRefreshing, Mode=OneWay}" Style="{StaticResource SweetButton}"/>
                <Button Content="Copy List" Style="{StaticResource OutlineButton}" Click="CopyProcessList_Click"/>
            </StackPanel>
        </Grid>

        <Border Style="{StaticResource SweetCard}" Grid.Row="1" Margin="3,0,3,12" Padding="12,9">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         PlaceholderText="Search process..."
                         Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         CornerRadius="5"
                         BorderThickness="1"
                         BorderBrush="{StaticResource RowBorder}"
                         Background="{StaticResource RowBg}"
                         Foreground="{StaticResource TextMain}"
                         PlaceholderForeground="{StaticResource TextMuted}"
                         FontFamily="Segoe UI"
                         FontSize="12"
                         Height="34"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}" Width="18" Height="18" Foreground="{StaticResource AccentMain}" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.OperationStatus, Mode=OneWay}" FontFamily="Segoe UI" FontSize="11" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" MaxWidth="360" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <ComboBox Grid.Column="2" ItemsSource="{x:Bind ViewModel.SortOptions}" SelectedItem="{x:Bind ViewModel.SelectedSort, Mode=TwoWay}" Height="34" Background="{StaticResource RowBg}" BorderBrush="{StaticResource RowBorder}" Foreground="{StaticResource TextMain}"/>
            </Grid>
        </Border>

        <!-- Terminal Table Column Headers -->
        <Grid Grid.Row="2" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Process" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Grid.Column="0"/>
            <TextBlock Text="Memory" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Grid.Column="1"/>
            <TextBlock Text="Action" FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Grid.Column="2" HorizontalAlignment="Right"/>
        </Grid>

        <!-- Process ListView (Sleek stripped-down terminal rows) -->
        <ListView ItemsSource="{x:Bind ViewModel.Processes}" SelectionMode="None" Grid.Row="3" Padding="0,0,0,16">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:ProcessItemVM">
                    <!-- Flat console output row -->
                    <Border Background="{StaticResource RowBg}" CornerRadius="4" Padding="10,3" Margin="3,0,3,3" BorderThickness="1" BorderBrush="{StaticResource RowBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Column 0: Name and ID -->
                            <StackPanel VerticalAlignment="Center" Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{x:Bind Id}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextDim}" Width="50"/>
                                <TextBlock Text="{x:Bind Name}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <!-- Column 1: Memory Allocation -->
                            <TextBlock Text="{x:Bind RamStr}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" VerticalAlignment="Center" Grid.Column="1"/>
                            
                            <!-- Column 2: Terminal Bracket Button -->
                            <StackPanel Grid.Column="2" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ProtectionLabel}" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                <Button Content="End" Click="EndTask_Click" IsEnabled="{x:Bind CanEndTask}" Style="{StaticResource DestructiveOutlineButton}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
