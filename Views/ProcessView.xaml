<Page
    x:Class="TAY.Views.ProcessView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <!-- Terminal Column Headers -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Margin="4,0,4,16">
            <TextBlock Text="PROCESS_MANAGER // ACTIVE_PROC" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="140"/>
            <TextBlock Text="ps_aux_dump.sh" FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Command Line Toolbar (Primary Action) -->
        <Border Style="{StaticResource SweetCard}" Grid.Row="1" Margin="4,0,4,16" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" Spacing="12">
                    <Button Content="[ refresh_proc ]" Command="{x:Bind ViewModel.LoadProcessesCommand}" IsEnabled="{x:Bind ViewModel.IsNotRefreshing, Mode=OneWay}" Style="{StaticResource SweetButton}"/>
                    <ProgressRing IsActive="{x:Bind ViewModel.IsRefreshing, Mode=OneWay}" Width="18" Height="18" Foreground="{StaticResource AccentMain}" VerticalAlignment="Center"/>
                    <Button Content="[ copy_list ]" Style="{StaticResource OutlineButton}" Click="CopyProcessList_Click"/>
                </StackPanel>
                
                <TextBox Grid.Column="2" Width="300" HorizontalAlignment="Right" PlaceholderText="filter_query..." Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" CornerRadius="4" BorderThickness="1" BorderBrush="{StaticResource RowBorder}" Background="{StaticResource RowBg}" Foreground="{StaticResource TextMain}" FontFamily="Consolas" FontSize="11" Height="28"/>
            </Grid>
        </Border>

        <!-- Terminal Table Column Headers -->
        <Grid Grid.Row="2" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="PID / CMD" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="80" Grid.Column="0"/>
            <TextBlock Text="HEAP_ALLOCATION" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="80" Grid.Column="1"/>
            <TextBlock Text="SIGNAL" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="80" Grid.Column="2" HorizontalAlignment="Right"/>
        </Grid>

        <!-- Process ListView (Sleek stripped-down terminal rows) -->
        <ListView ItemsSource="{x:Bind ViewModel.Processes}" SelectionMode="None" Grid.Row="3" Padding="0,0,0,16">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:ProcessItemVM">
                    <!-- Flat console output row -->
                    <Border Background="{StaticResource RowBg}" CornerRadius="4" Padding="12,3" Margin="4,0,4,3" BorderThickness="1" BorderBrush="{StaticResource RowBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Column 0: Name and ID -->
                            <StackPanel VerticalAlignment="Center" Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{x:Bind Id}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextDim}" Width="50"/>
                                <TextBlock Text="{x:Bind Name}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            
                            <!-- Column 1: Memory Allocation -->
                            <TextBlock Text="{x:Bind RamStr}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource AccentWarning}" VerticalAlignment="Center" Grid.Column="1"/>
                            
                            <!-- Column 2: Terminal Bracket Button -->
                            <Button Content="[ end_task ]" Command="{x:Bind EndTaskCommand}" Style="{StaticResource DestructiveOutlineButton}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
