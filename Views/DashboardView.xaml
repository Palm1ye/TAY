<Page
    x:Class="TAY.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TAY.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="14,14,14,12" Spacing="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="21" FontWeight="SemiBold" />
                    <TextBlock Text="Live system status - refreshed continuously" FontSize="11" Foreground="{StaticResource TextMuted}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Style="{StaticResource GhostButton}" Click="CopySnapshot_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                            <TextBlock Text="Snapshot" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Click="Refresh_Click">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE72C;" FontSize="13" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Style="{StaticResource SweetCard}" Padding="16">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Width="49" Height="49" CornerRadius="8" Background="{StaticResource AccentMain}">
                        <FontIcon Glyph="{x:Bind ViewModel.DiagnosisIconGlyph, Mode=OneWay}" FontSize="24" Foreground="#111111" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{x:Bind ViewModel.DiagnosisTitle, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="{x:Bind ViewModel.DiagnosisDetail, Mode=OneWay}" FontSize="12" Foreground="{StaticResource TextDim}" TextWrapping="Wrap" MaxLines="2" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="{x:Bind ViewModel.DiagnosisActionText, Mode=OneWay}" Style="{StaticResource SweetButton}" Click="OpenDiagnosis_Click" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource CompactCard}" MinHeight="114">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE950;" FontSize="12" Foreground="{StaticResource AccentMain}" />
                            <TextBlock Text="CPU" FontSize="12" Foreground="{StaticResource TextDim}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.CpuUsage, Mode=OneWay}" FontSize="23" FontWeight="SemiBold" Margin="0,7,0,0" />
                        <controls:SparklineControl Grid.Row="2"
                                                   Values="{x:Bind ViewModel.CpuSparklineValues, Mode=OneWay}"
                                                   Stroke="{StaticResource AccentMain}"
                                                   Fill="{StaticResource AccentMainSoft}"
                                                   LineThickness="1.8"
                                                   Height="24"
                                                   Margin="0,0,0,0" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.CpuDetail, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CompactCard}" MinHeight="114">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8B7;" FontSize="12" Foreground="{StaticResource AccentMemory}" />
                            <TextBlock Text="Memory" FontSize="12" Foreground="{StaticResource TextDim}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.RamUsage, Mode=OneWay}" FontSize="23" FontWeight="SemiBold" Margin="0,7,0,0" />
                        <controls:SparklineControl Grid.Row="2"
                                                   Values="{x:Bind ViewModel.RamSparklineValues, Mode=OneWay}"
                                                   Stroke="{StaticResource AccentMemory}"
                                                   LineThickness="1.8"
                                                   Height="24"
                                                   Margin="0,0,0,0" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.RamDetail, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CompactCard}" MinHeight="114">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7F4;" FontSize="12" Foreground="{StaticResource AccentGpu}" />
                            <TextBlock Text="GPU" FontSize="12" Foreground="{StaticResource TextDim}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.GpuUsage, Mode=OneWay}" FontSize="23" FontWeight="SemiBold" Margin="0,7,0,0" />
                        <controls:SparklineControl Grid.Row="2"
                                                   Values="{x:Bind ViewModel.GpuSparklineValues, Mode=OneWay}"
                                                   Stroke="{StaticResource AccentGpu}"
                                                   Fill="{StaticResource AccentGreenSoft}"
                                                   LineThickness="1.8"
                                                   Height="24"
                                                   Margin="0,0,0,0" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.GpuDetail, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CompactCard}" MinHeight="114">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE839;" FontSize="12" Foreground="{StaticResource AccentPurple}" />
                            <TextBlock Text="Network" FontSize="12" Foreground="{StaticResource TextDim}" />
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.NetworkUsage, Mode=OneWay}" FontSize="22" FontWeight="SemiBold" Margin="0,7,0,0" />
                        <controls:SparklineControl Grid.Row="2"
                                                   Values="{x:Bind ViewModel.NetworkSparklineValues, Mode=OneWay}"
                                                   Stroke="{StaticResource AccentPurple}"
                                                   LineThickness="1.8"
                                                   Height="24"
                                                   Margin="0,0,0,0" />
                        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.NetworkDetail, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Text="QUICK ACTIONS" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="2,8,0,0" />

            <Border Style="{StaticResource SweetCard}" Padding="0">
                <StackPanel>
                    <Button Style="{StaticResource ToolButton}" Click="OpenClean_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34" Height="34" CornerRadius="5" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Clean caches" FontSize="14" />
                                <TextBlock Text="{x:Bind ViewModel.DiskFree, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                            </StackPanel>
                            <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Rectangle Height="1" Fill="{StaticResource RowBorder}" />

                    <Button Style="{StaticResource ToolButton}" Click="OpenStartup_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="34" Height="34" CornerRadius="5" Background="#333333" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                <FontIcon Glyph="&#xE756;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Review startup" FontSize="14" />
                                <TextBlock Text="{x:Bind ViewModel.ProcessStatus, Mode=OneWay}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                            </StackPanel>
                            <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
