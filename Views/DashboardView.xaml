<Page
    x:Class="TAY.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:TAY.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d"
    Unloaded="Page_Unloaded"
    Background="Transparent">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition/>
        </TransitionCollection>
    </Page.Transitions>

    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Margin="4,0,4,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="SYSTEM // MONITOR" FontFamily="Consolas" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" CharacterSpacing="140"/>
                    <TextBlock Text="sys_overview.sh" FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="QuickBoostBtn" Content="[ quick_boost ]" Style="{StaticResource OutlineButton}" Foreground="{StaticResource AccentMain}" Click="QuickBoost_Click"/>
                <Button Content="[ copy_snapshot ]" Style="{StaticResource OutlineButton}" Click="CopySnapshot_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- Bento Box Layout Grid -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Row 0: Large Telemetry Bento Box Items -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bento Card 1: CPU Load -->
            <Border Style="{StaticResource SweetCard}" Grid.Column="0" Grid.Row="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Text="CPU // LOAD" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80"/>
                    </StackPanel>
                    
                    <!-- Huge prominent monospace stats value -->
                    <StackPanel Grid.Row="1" Margin="0,16,0,16" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.CpuUsage, Mode=OneWay}" FontFamily="Consolas" FontSize="38" FontWeight="Bold" Foreground="{StaticResource AccentMain}"/>
                        <TextBlock Text="telemetry_active" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    
                    <!-- Thin minimalist progress line -->
                    <ProgressBar Grid.Row="2" Value="{x:Bind ViewModel.CpuValue, Mode=OneWay}" Minimum="0" Maximum="100" Height="2" Foreground="{StaticResource AccentMain}" Background="#104AEADC"/>
                </Grid>
            </Border>

            <!-- Bento Card 2: Memory Load -->
            <Border Style="{StaticResource SweetCard}" Grid.Column="1" Grid.Row="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Text="RAM // USAGE" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80"/>
                    </StackPanel>
                    
                    <!-- Huge prominent monospace stats value -->
                    <StackPanel Grid.Row="1" Margin="0,16,0,16" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.RamUsage, Mode=OneWay}" FontFamily="Consolas" FontSize="38" FontWeight="Bold" Foreground="{StaticResource AccentWarning}"/>
                        <TextBlock Text="heap_allocated" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    
                    <!-- Thin minimalist progress line -->
                    <ProgressBar Grid.Row="2" Value="{x:Bind ViewModel.RamValue, Mode=OneWay}" Minimum="0" Maximum="100" Height="2" Foreground="{StaticResource AccentWarning}" Background="#10FFD66A"/>
                </Grid>
            </Border>

            <!-- Bento Card 3: GPU Load -->
            <Border Style="{StaticResource SweetCard}" Grid.Column="2" Grid.Row="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <TextBlock Text="GPU // LOAD" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Margin="0,16,0,16" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.GpuUsage, Mode=OneWay}" FontFamily="Consolas" FontSize="38" FontWeight="Bold" Foreground="{StaticResource AccentInfo}"/>
                        <TextBlock Text="render_engine_active" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    
                    <ProgressBar Grid.Row="2" Value="{x:Bind ViewModel.GpuValue, Mode=OneWay}" Minimum="0" Maximum="100" Height="2" Foreground="{StaticResource AccentInfo}" Background="#103B9FFF"/>
                </Grid>
            </Border>

            <!-- Bento Card 4: Storage Load -->
            <Border Style="{StaticResource SweetCard}" Grid.Column="0" Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="DISK // USAGE" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80"/>
                    <StackPanel Grid.Row="1" Margin="0,14,0,14" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.DiskUsage, Mode=OneWay}" FontFamily="Consolas" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextMain}"/>
                        <TextBlock Text="{x:Bind ViewModel.DiskFree, Mode=OneWay}" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    <ProgressBar Grid.Row="2" Value="{x:Bind ViewModel.DiskValue, Mode=OneWay}" Minimum="0" Maximum="100" Height="2" Foreground="{StaticResource AccentMain}" Background="#104AEADC"/>
                </Grid>
            </Border>

            <!-- Bento Card 5: Uptime & Power Plan -->
            <Border Style="{StaticResource SweetCard}" Grid.Column="1" Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="SYS // UPTIME" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80"/>
                    <StackPanel Grid.Row="1" Margin="0,14,0,10" VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.Uptime, Mode=OneWay}" FontFamily="Consolas" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextMain}"/>
                        <TextBlock Text="kernel_up_status" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                    <ComboBox Grid.Row="2" ItemsSource="{x:Bind ViewModel.PowerPlans, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPlan, Mode=TwoWay}" DisplayMemberPath="Name" HorizontalAlignment="Stretch" CornerRadius="4" Background="{StaticResource RowBg}" Foreground="{StaticResource TextMain}" BorderBrush="{StaticResource RowBorder}" FontFamily="Consolas" FontSize="11" Height="28"/>
                </Grid>
            </Border>

            <!-- Bento Card 6: Process Count -->
            <Border Style="{StaticResource SweetCard}" Grid.Column="2" Grid.Row="1">
                <StackPanel>
                    <TextBlock Text="PROC // ACTIVE" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80"/>
                    <TextBlock Text="{x:Bind ViewModel.ProcessCount, Mode=OneWay}" FontFamily="Consolas" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentWarning}" Margin="0,14,0,2"/>
                    <TextBlock Text="running_processes" FontFamily="Consolas" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
            </Border>

            <!-- LiveCharts2 Telemetry History Graph -->
            <Border Style="{StaticResource SweetCard}" Grid.Row="2" Grid.Column="0" Margin="4,4,4,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="TELEMETRY // CPU_RAM_GPU" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80" Margin="0,0,0,12" Grid.Row="0"/>
                    
                    <!-- LiveCharts2 Real Cartesian Chart Integration -->
                    <Grid Grid.Row="1">
                        <Border BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Height="140" Background="{StaticResource RowBg}" CornerRadius="4" Padding="4">
                            <lvc:CartesianChart
                                Series="{Binding CpuSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                Height="130"
                                Background="Transparent"/>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- System Hardware Terminal Specs (Span 2 columns, right) -->
            <Border Style="{StaticResource SweetCard}" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="4,4,4,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="SYS // DENSE_SPECIFICATIONS_DUMP" FontFamily="Consolas" FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextDim}" CharacterSpacing="80" Margin="0,0,0,16" Grid.Row="0"/>
                    
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Processor -->
                        <TextBlock Text="SYS // PROCESSOR     :" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Row="0" Grid.Column="0" Margin="0,0,0,10"/>
                        <TextBlock Text="{x:Bind ViewModel.CpuModel, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" Grid.Row="0" Grid.Column="1" TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>
                        
                        <!-- Graphics Card -->
                        <TextBlock Text="SYS // GRAPHICS CARD :" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Row="1" Grid.Column="0" Margin="0,0,0,10"/>
                        <TextBlock Text="{x:Bind ViewModel.GpuModel, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" Grid.Row="1" Grid.Column="1" TextTrimming="CharacterEllipsis" Margin="0,0,0,10"/>
                        
                        <!-- System Memory -->
                        <TextBlock Text="SYS // MEMORY        :" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Row="2" Grid.Column="0" Margin="0,0,0,10"/>
                        <TextBlock Text="{x:Bind ViewModel.RamAmount, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"/>
                        
                        <!-- Baseboard -->
                        <TextBlock Text="SYS // BASEBOARD     :" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMuted}" Grid.Row="3" Grid.Column="0"/>
                        <TextBlock Text="{x:Bind ViewModel.MotherboardModel, Mode=OneWay}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextMain}" Grid.Row="3" Grid.Column="1" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
