<Application
    x:Class="TAY.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:TAY.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <SolidColorBrush x:Key="WindowCaptionBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="WindowCaptionBackgroundDisabled" Color="Transparent"/>

            <SolidColorBrush x:Key="BgBase" Color="#0A1220" />
            <SolidColorBrush x:Key="BgSidebar" Color="#0D1B2A" />
            <SolidColorBrush x:Key="AccentMain" Color="#4AEADC" />
            <SolidColorBrush x:Key="AccentWarning" Color="#F2C66D" />
            <SolidColorBrush x:Key="AccentDanger" Color="#F47C7C" />
            <SolidColorBrush x:Key="AccentInfo" Color="#3B9FFF" />
            <SolidColorBrush x:Key="TextMain" Color="#E8EDF3" />
            <SolidColorBrush x:Key="TextDim" Color="#8899AA" />
            <SolidColorBrush x:Key="TextMuted" Color="#5A6B7E" />
            <SolidColorBrush x:Key="CardBg" Color="#0F2133" />
            <SolidColorBrush x:Key="CardBorder" Color="#1A3A5C" />

            <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#4AEADC" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#5CF0E6" />
            <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#38D4C8" />
            <SolidColorBrush x:Key="ToggleSwitchFillOff" Color="#152535" />
            <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver" Color="#1C3045" />
            <SolidColorBrush x:Key="ToggleSwitchFillOffPressed" Color="#243B55" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOff" Color="#2A4060" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOffPointerOver" Color="#3A5575" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOffPressed" Color="#6088AA" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOn" Color="#4AEADC" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#5CF0E6" />
            <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed" Color="#38D4C8" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#0A1220" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#0D1B2A" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed" Color="#0A1220" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#6088AA" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPointerOver" Color="#E8EDF3" />
            <SolidColorBrush x:Key="ToggleSwitchKnobFillOffPressed" Color="#6088AA" />

            <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarTrackBackgroundPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarTrackBackgroundPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarTrackBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarTrackBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarTrackBorderBrushPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="#2A4060" />
            <SolidColorBrush x:Key="ScrollBarThumbBackgroundPointerOver" Color="#4AEADC" />
            <SolidColorBrush x:Key="ScrollBarThumbBackgroundPressed" Color="#4AEADC" />
            <SolidColorBrush x:Key="ScrollBarButtonBackground" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonBackgroundPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonBackgroundPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonForeground" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonForegroundPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonForegroundPressed" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonBorderBrush" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPointerOver" Color="Transparent" />
            <SolidColorBrush x:Key="ScrollBarButtonBorderBrushPressed" Color="Transparent" />
            <x:Double x:Key="ScrollBarSize">6</x:Double>
            <x:Double x:Key="ScrollBarButtonGridLength">0</x:Double>
            <x:Double x:Key="ScrollBarMinHeight">20</x:Double>
            <x:Double x:Key="ScrollBarMinWidth">20</x:Double>
            <Thickness x:Key="ScrollBarTrackBorderThemeThickness">0</Thickness>

            <Style TargetType="ScrollBar">
                <Setter Property="MinWidth" Value="6"/>
                <Setter Property="Width" Value="6"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="SweetCard" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardBg}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                <Setter Property="Margin" Value="4"/>
            </Style>

            <Style x:Key="SweetButton" TargetType="Button">
                <Setter Property="Background" Value="#244AEADC"/>
                <Setter Property="Foreground" Value="{StaticResource AccentMain}"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="18,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>

            <Style x:Key="OutlineButton" TargetType="Button">
                <Setter Property="Background" Value="#12FFFFFF"/>
                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="18,8"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>

            <Style x:Key="DestructiveOutlineButton" TargetType="Button">
                <Setter Property="Background" Value="#20F47C7C"/>
                <Setter Property="Foreground" Value="{StaticResource AccentDanger}"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="14,6"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="6"/>
            </Style>

            <SolidColorBrush x:Key="RowBg" Color="#0C1E3A" />
            <SolidColorBrush x:Key="RowBgAlt" Color="#0A182E" />
            <SolidColorBrush x:Key="RowBorder" Color="#1A3A5C" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
