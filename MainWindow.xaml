<Window
    x:Class="TAY.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TAY Optimizer">

    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#202633" Offset="0"/>
                <GradientStop Color="#121922" Offset="0.34"/>
                <GradientStop Color="#0A0C11" Offset="0.78"/>
                <GradientStop Color="#08090D" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.Resources>
            <Style x:Key="RailButtonBaseStyle" TargetType="Button">
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="RootGrid" 
                                  Background="{TemplateBinding Background}" 
                                  BorderBrush="{TemplateBinding BorderBrush}" 
                                  BorderThickness="{TemplateBinding BorderThickness}" 
                                  CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  ContentTransitions="{TemplateBinding ContentTransitions}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Padding="{TemplateBinding Padding}"
                                                  Foreground="{TemplateBinding Foreground}"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background" Value="#15FFFFFF"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootGrid.Background" Value="#25FFFFFF"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled"/>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ActiveTabStyle" TargetType="Button" BasedOn="{StaticResource RailButtonBaseStyle}">
                <Setter Property="Background" Value="#12FFFFFF"/>
                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="InactiveTabStyle" TargetType="Button" BasedOn="{StaticResource RailButtonBaseStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            </Style>

            <Style x:Key="RailIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="5"/>
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="224"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.Column="0" Grid.ColumnSpan="2" IsHitTestVisible="False" Opacity="0.72">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.82,0.58">
                    <GradientStop Color="#3A3D8CFF" Offset="0"/>
                    <GradientStop Color="#28255E83" Offset="0.24"/>
                    <GradientStop Color="#10223B45" Offset="0.48"/>
                    <GradientStop Color="#00000000" Offset="0.82"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Grid.Column="1" IsHitTestVisible="False" Opacity="0.54">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0.05,0.1" EndPoint="0.95,0.85">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#18325974" Offset="0.26"/>
                    <GradientStop Color="#1E4F6C68" Offset="0.48"/>
                    <GradientStop Color="#14202430" Offset="0.72"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Grid.Column="0" Grid.ColumnSpan="2" IsHitTestVisible="False" Opacity="0.22">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="1,1" EndPoint="0.3,0.45">
                    <GradientStop Color="#30D98CCB" Offset="0"/>
                    <GradientStop Color="#1268478B" Offset="0.16"/>
                    <GradientStop Color="#00000000" Offset="0.54"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Grid.Column="0" Grid.ColumnSpan="2" IsHitTestVisible="False" Opacity="0.5">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="0.54"/>
                    <GradientStop Color="#53000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Custom Titlebar Draggable Region -->
        <Grid x:Name="AppTitleBar" Grid.Column="0" Grid.ColumnSpan="2" Height="32" Background="Transparent" VerticalAlignment="Top" Canvas.ZIndex="999"/>

        <Grid Grid.Column="0" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,1,0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#D90A0D13" Offset="0"/>
                    <GradientStop Color="#E8070A0F" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/> <!-- Titlebar spacer -->
                <RowDefinition Height="48"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/> <!-- Tab buttons ScrollViewer -->
                <RowDefinition Height="Auto"/> <!-- Bottom compact terminal -->
            </Grid.RowDefinitions>

            <StackPanel x:Name="AppLogoPanel" Grid.Row="1" Orientation="Horizontal" Margin="14,0,0,0" Spacing="8" VerticalAlignment="Center">
                <Image x:Name="AppLogoImage" Width="20" Height="20" VerticalAlignment="Center">
                    <Image.Source>
                        <SvgImageSource UriSource="ms-appx:///Assets/tay.svg"/>
                    </Image.Source>
                </Image>
                <TextBlock x:Name="AppTitleText"
                           Text="TAY"
                           FontFamily="Segoe UI"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="{StaticResource AccentMain}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel x:Name="SidebarButtonsPanel" Grid.Row="2" Margin="10,4,8,12" Spacing="6" Orientation="Horizontal">
                <Button Style="{StaticResource RailIconButtonStyle}" HorizontalAlignment="Left" Click="BackButton_Click">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                </Button>
                <Button Style="{StaticResource RailIconButtonStyle}" HorizontalAlignment="Left" Click="ToggleSidebarButton_Click">
                    <FontIcon Glyph="&#xE700;" FontSize="14"/>
                </Button>
            </StackPanel>

            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,8">
                <StackPanel Margin="8,0,8,0" Spacing="3">
                    <Button x:Name="TabOptimize" Tag="Optimize" Click="OnTabClicked" Style="{StaticResource ActiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE80F;" FontSize="15"/>
                            <TextBlock x:Name="DashboardLabel" Text="Dashboard"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TabBoost" Tag="Boost" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🚀" FontFamily="Segoe UI Emoji" FontSize="14" Width="15" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="BoostLabel" Text="Boost Tuning"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TabHardware" Tag="Hardware" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE950;" FontSize="15"/>
                            <TextBlock x:Name="HardwareLabel" Text="Hardware"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TabStartup" Tag="Startup" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE945;" FontSize="15"/>
                            <TextBlock x:Name="StartupLabel" Text="Startup"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TabClean" Tag="Clean" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE74D;" FontSize="15"/>
                            <TextBlock x:Name="CleanerLabel" Text="Cleaner"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TabStorage" Tag="Storage" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xEDA2;" FontSize="15"/>
                            <TextBlock x:Name="DiskLabel" Text="Disk"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TabProcesses" Tag="Processes" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8F1;" FontSize="15"/>
                            <TextBlock x:Name="ProcessesLabel" Text="Processes"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="TabSettings" Tag="Settings" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE713;" FontSize="15"/>
                            <TextBlock x:Name="SettingsLabel" Text="Settings"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Collapsible Sidebar Terminal (Row 4) -->
            <Border x:Name="SidebarTerminalPanel" Grid.Row="4" 
                    Background="#070F1A" 
                    BorderBrush="{StaticResource CardBorder}" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Margin="8,0,8,8" 
                    Padding="10,8">
                <Grid>
                    <!-- Expanded State Console -->
                    <Grid x:Name="SidebarTerminalExpanded">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Fill="#4AEADC" VerticalAlignment="Center"/>
                                <TextBlock Text="Activity" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                            </StackPanel>
                            
                            <Button Grid.Column="1" Content="Clear" Style="{StaticResource GhostButton}" Padding="6,2" FontSize="10" Click="ClearTerminal_Click" Height="22"/>
                        </Grid>
                        
                        <ListView x:Name="TerminalListView" Grid.Row="1" 
                                  ItemsSource="{x:Bind LogLines, Mode=OneWay}" 
                                  SelectionMode="None" 
                                  Background="Transparent" 
                                  Padding="0" 
                                  BorderThickness="0" 
                                  MaxHeight="120"
                                  Height="120">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="9.5" Foreground="#83F6EC" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                    
                    <!-- Collapsed/Compact State Icon -->
                    <Grid x:Name="SidebarTerminalCollapsed" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Style="{StaticResource RailIconButtonStyle}" Click="ToggleSidebarFromTerminal_Click" ToolTipService.ToolTip="System Logs Online">
                            <Grid>
                                <Ellipse Width="14" Height="14" Fill="#4AEADC" Opacity="0.2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <FontIcon Glyph="&#xE756;" FontSize="13" Foreground="{StaticResource AccentMain}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="1" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/> <!-- Titlebar spacer -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Frame x:Name="RootFrame" Grid.Row="1" Background="Transparent"/>
        </Grid>
    </Grid>
</Window>
