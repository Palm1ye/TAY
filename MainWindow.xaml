<Window
    x:Class="TAY.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="TAY Optimizer">

    <Grid x:Name="RootGrid" Background="#101217">
        <Grid.Resources>
            <ControlTemplate x:Key="ShellTabTemplate" TargetType="Button">
                <Grid x:Name="Root"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        ContentTransitions="{TemplateBinding ContentTransitions}"
                        Foreground="{TemplateBinding Foreground}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,2" />
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="Root.Background" Value="#2B2B2B" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Target="Root.Background" Value="#343434" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Grid>
            </ControlTemplate>

            <ControlTemplate x:Key="ActiveShellTabTemplate" TargetType="Button">
                <Grid x:Name="Root"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="{TemplateBinding CornerRadius}">
                    <ContentPresenter
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        ContentTransitions="{TemplateBinding ContentTransitions}"
                        Foreground="{TemplateBinding Foreground}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,3" />
                    <Rectangle Height="2"
                               Width="22"
                               Fill="{StaticResource AccentMain}"
                               RadiusX="1"
                               RadiusY="1"
                               VerticalAlignment="Bottom" />
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="Root.Background" Value="#303030" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Target="Root.Background" Value="#363636" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Grid>
            </ControlTemplate>

            <Style x:Key="InactiveTabStyle" TargetType="Button">
                <Setter Property="Width" Value="34" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource TextDim}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Template" Value="{StaticResource ShellTabTemplate}" />
            </Style>

            <Style x:Key="ActiveTabStyle" TargetType="Button" BasedOn="{StaticResource InactiveTabStyle}">
                <Setter Property="Foreground" Value="{StaticResource AccentMain}" />
                <Setter Property="Background" Value="#2B2B2B" />
                <Setter Property="Template" Value="{StaticResource ActiveShellTabTemplate}" />
            </Style>
        </Grid.Resources>

        <Border x:Name="Shell"
                Background="{StaticResource BgSurface}"
                BorderBrush="#343434"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="34" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="40" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>

                <Grid Background="#202020" BorderBrush="#343434" BorderThickness="0,0,0,1">
                    <Grid x:Name="AppTitleBar" Background="Transparent" Margin="122,0,170,0" />

                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center"
                                Canvas.ZIndex="1">
                        <Image Width="18" Height="18" VerticalAlignment="Center">
                            <Image.Source>
                                <SvgImageSource UriSource="ms-appx:///Assets/tay.svg" />
                            </Image.Source>
                        </Image>
                        <TextBlock Text="TAY Optimizer"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMain}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button x:Name="PinButton"
                            Style="{StaticResource IconGhostButton}"
                            HorizontalAlignment="Right"
                            Margin="0,0,132,0"
                            Canvas.ZIndex="1"
                            Click="PinButton_Click"
                            ToolTipService.ToolTip="Pin window on top">
                        <FontIcon Glyph="&#xE840;" FontSize="13" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Background="#202020" BorderBrush="#343434" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                Margin="16,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Button x:Name="TabDashboard" Tag="Dashboard" Click="OnTabClicked" Style="{StaticResource ActiveTabStyle}" ToolTipService.ToolTip="Dashboard">
                            <FontIcon Glyph="&#xE80F;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabBoost" Tag="Boost" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Boost Tuning">
                            <FontIcon Glyph="&#xE945;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabHardware" Tag="Hardware" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Hardware">
                            <FontIcon Glyph="&#xE950;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabStartup" Tag="Startup" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Startup">
                            <FontIcon Glyph="&#xE756;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabCleaner" Tag="Cleaner" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Cleaner">
                            <FontIcon Glyph="&#xE74D;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabDisk" Tag="Disk" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Disk">
                            <FontIcon Glyph="&#xEDA2;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabProcesses" Tag="Processes" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Processes">
                            <FontIcon Glyph="&#xE9D2;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabNetwork" Tag="Network" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Network">
                            <FontIcon Glyph="&#xE839;" FontSize="15" />
                        </Button>
                        <Button x:Name="TabActivity" Tag="Activity" Click="OnTabClicked" Style="{StaticResource InactiveTabStyle}" ToolTipService.ToolTip="Activity">
                            <FontIcon Glyph="&#xE9D9;" FontSize="15" />
                        </Button>
                    </StackPanel>
                    <Button x:Name="TabSettings"
                            Grid.Column="1"
                            Tag="Settings"
                            Click="OnTabClicked"
                            Style="{StaticResource InactiveTabStyle}"
                            HorizontalAlignment="Right"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontSize="15" />
                    </Button>
                </Grid>

                <Grid Grid.Row="2" Padding="13,6,13,5" BorderBrush="#303030" BorderThickness="0,0,0,1">
                    <Border Background="{StaticResource BgInput}"
                            BorderBrush="#424242"
                            BorderThickness="1"
                            CornerRadius="4">
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Glyph="&#xE721;"
                                      FontSize="12"
                                      Foreground="{StaticResource TextMuted}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     PlaceholderText="Search..."
                                     TextChanged="SearchBox_TextChanged"
                                     KeyDown="SearchBox_KeyDown"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0,2,0,0"
                                     FontSize="13"
                                     Foreground="{StaticResource TextMain}"
                                     PlaceholderForeground="{StaticResource TextMuted}" />
                            <Border Grid.Column="2"
                                    Margin="0,4,6,4"
                                    Padding="5,0"
                                    Background="#3A3A3A"
                                    BorderBrush="#565656"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                <TextBlock Text="Ctrl K"
                                           x:Name="SearchShortcutText"
                                           FontFamily="Consolas"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <Frame x:Name="RootFrame"
                       Grid.Row="3"
                       Background="Transparent" />

                <Grid Grid.Row="4"
                      Background="#202020"
                      Padding="13,0"
                      BorderBrush="#303030"
                      BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal"
                                Spacing="5"
                                VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreen}" />
                        <TextBlock Text="Connected"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="FooterCpuText" Text="C --%" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        <TextBlock x:Name="FooterMemoryText" Text="M --%" FontSize="11" Foreground="{StaticResource TextMuted}" />
                        <TextBlock x:Name="FooterGpuText" Text="G --%" FontSize="11" Foreground="{StaticResource TextMuted}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
